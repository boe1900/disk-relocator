    {
      "app_id": "telegram-desktop",
      "display_name": "Telegram Desktop",
      "tier": "supported",
      "distribution": ["direct-download"],
      "tested_versions": ["macOS 13+", "Telegram 5.x"],
      "process_names": ["Telegram"],
      "source_paths": [
        "~/Library/Application Support/Telegram Desktop"
      ],
      "target_path_template": "{target_root}/AppData/Telegram Desktop",
      "precheck_rules": {
        "require_process_stopped": true,
        "require_full_disk_access": true,
        "allow_bootstrap_if_source_missing": true
      },
      "health_checks": [
        {
          "type": "is_symlink",
          "path": "~/Library/Application Support/Telegram Desktop"
        },
        {
          "type": "target_exists",
          "path": "{target_root}/AppData/Telegram Desktop"
        },
        {
          "type": "rw_probe",
          "path": "{target_root}/AppData/Telegram Desktop"
        }
      ],
      "rollback_rules": {
        "remove_symlink_first": true,
        "restore_backup_dir": true,
        "cleanup_incomplete_target": true
      },
      "notes": "迁移前必须完全退出应用。首次引导模式可在源路径缺失时直接初始化目标并创建软链接。"
    },

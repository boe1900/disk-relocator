{
  "schema_version": "2.1.0",
  "updated_at": "2026-03-09",
  "engine_defaults": {
    "app_level": {
      "availability": "active",
      "process_policy": {
        "require_process_stopped": true,
        "require_full_disk_access": true
      }
    },
    "unit_level": {
      "enabled": true,
      "risk_level": "stable",
      "requires_confirmation": false,
      "allow_bootstrap_if_source_missing": false,
      "auto_health_checks": ["is_symlink", "target_exists", "rw_probe"],
      "auto_rollback": ["remove_symlink_first", "restore_backup_dir", "cleanup_incomplete_target"]
    }
  },
  "profiles": [
    {
      "app_id": "wechat-non-mas",
      "display_name": "WeChat (Non-MAS)",
      "description_i18n": {
        "zh": "迁移微信 xwechat_files 整目录。",
        "en": "Migrate the whole WeChat xwechat_files directory."
      },
      "bundle_ids": ["com.tencent.xinWeChat"],
      "process_names": ["WeChat"],
      "units": [
        {
          "unit_id": "xwechat-files",
          "display_name": "xwechat_files",
          "category": "media",
          "source_path": "~/Library/Containers/com.tencent.xinWeChat/Data/Documents/xwechat_files",
          "target_path_template": "{target_root}/AppData/WeChat/xwechat_files",
          "allow_bootstrap_if_source_missing": true
        }
      ]
    }
  ]
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Disk Relocator",
  "version": "0.1.0",
  "identifier": "com.data-dock.disk-relocator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Disk Relocator",
        "width": 1200,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [],
    "targets": "all"
  }
}
